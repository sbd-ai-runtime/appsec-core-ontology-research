{
  "version": 1,
  "defaults": {
    "from": "markdown+smart+raw_attribute",
    "standalone": true,
    "pdf_engine": "xelatex",
    "pandoc_args": [
      "-V",
      "fontsize=11pt",
      "-V",
      "mainfont=STIX Two Text",
      "-V",
      "mathfont=STIX Two Math",
      "-V",
      "monofont=Menlo",
      "-V",
      "geometry:margin=1in",
      "-V",
      "colorlinks=true",
      "-V",
      "urlcolor=blue",
      "--include-in-header",
      "styles/paper-preprint.tex"
    ]
  },
  "documents": [
    {
      "id": "paper1",
      "title": "AppSec Core: A Normalized Ontology for Security Requirements Across Heterogeneous Frameworks",
      "sources": [
        "papers/01-appsec-core-normalized-ontology/source/manuscript.md"
      ],
      "output": "papers/01-appsec-core-normalized-ontology/pdf/appsec_core_normalized_ontology.pdf",
      "metadata": {}
    },
    {
      "id": "paper2",
      "title": "Coverage-Preserving Compilation of Normative and Empirical Security Knowledge",
      "sources": [
        "papers/02-coverage-preserving-knowledge-compilation/source/manuscript.md"
      ],
      "output": "papers/02-coverage-preserving-knowledge-compilation/pdf/coverage_preserving_knowledge_compilation.pdf",
      "metadata": {}
    },
    {
      "id": "paper3",
      "title": "Ontology-Grounded Retrieval for Auditable LLM-Assisted Secure Code Generation",
      "sources": [
        "papers/03-ontology-grounded-retrieval/source/manuscript.md"
      ],
      "output": "papers/03-ontology-grounded-retrieval/pdf/ontology_grounded_retrieval.pdf",
      "metadata": {}
    }
  ]
}
