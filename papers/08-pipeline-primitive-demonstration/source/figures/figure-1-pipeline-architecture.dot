// Figure 1 — Pipeline Primitive Architecture
// Source: P8 manuscript §3
// Render: dot -Tsvg figure-1-pipeline-architecture.dot -o figure-1-pipeline-architecture.svg
//         dot -Tpdf figure-1-pipeline-architecture.dot -o figure-1-pipeline-architecture.pdf
// Layout: top-to-bottom pipeline flow with feeder branch and closure anchors.
//   Re-authored 2026-05-16 for legibility: TB rankdir, fontsize +3pt,
//   simplified labels (long parentheticals moved to caption), cleaner closure
//   anchor cluster.

digraph p8_pipeline_architecture {
  rankdir=TB;
  fontname="STIX Two Text";
  bgcolor="white";
  // Constrain layout to roughly letter-textwidth aspect so the figure does
  // not shrink dramatically when embedded at width=\linewidth.
  size="6.5,7.0!";
  ratio=compress;
  nodesep=0.30;
  ranksep=0.45;
  splines=true;
  node [shape=box, style="rounded,filled", fontname="STIX Two Text", color="#2c3e50", fillcolor="white", fontsize=14, margin="0.16,0.10"];
  edge [fontname="STIX Two Text", color="#2c3e50", fontsize=11];

  // Main pipeline stages (vertical spine)
  ES   [label="Stage 1 — External-source corpus\n31 sources"];
  P7   [label="Stage 2 — Normalization pipeline\nclaim-centric two-stage"];
  SUB  [label="Stage 3 — Normalized substrate\n3,861 items · 18,673 GROUNDED claims", fillcolor="#e8f4f8"];
  V1   [label="Stage 4 — AppSec Core V1 ontology\n259 entities · 10 slices", fillcolor="#e8f4f8"];
  COV  [label="Stage 5 — Manual coverage analysis\n202 / 202 substantive · 38 reclassified via §26", fillcolor="#fff3e0"];
  FROZ [label="Stage 7 — Cycle B frozen snapshot\ntag cycle-b-frozen-2026-05-12", fillcolor="#dceadc"];

  // Stage 6 feeders (stacked vertically alongside V1 → COV portion of the spine)
  MAN  [label="Stage 6a — Manual content surfaces\n15 chapters · 322 .md files", fillcolor="#fff3e0"];
  KG   [label="Stage 6b — KG runtime v1.2\n1,964 linkage records", fillcolor="#fff3e0"];

  // Main flow (solid edges, vertical spine)
  ES   -> P7   [label="  lift + ground"];
  P7   -> SUB  [label="  claim-centric"];
  SUB  -> V1   [label="  bind via slice + entity IRI"];
  V1   -> COV  [label="  V1 → Manual analysis"];
  COV  -> FROZ [label="  empirical findings"];

  // Stage 6 feeders into COV
  MAN  -> COV  [label="  prose + traceability"];
  KG   -> COV  [label="  linkage records"];

  // Stack MAN above KG to the right of the spine, both feeding into COV.
  // Place MAN at the same rank as V1, KG one rank below.
  { rank=same; V1; MAN; }

  // Cross-repository closure anchors (dashed edges into FROZ),
  // de-emphasised in grey to keep visual weight on the main flow.
  edge [style=dashed, color="#7f8c8d", fontcolor="#7f8c8d"];
  V1  -> FROZ [label="V1 anchor"];
  MAN -> FROZ [label="Manual anchor"];
  KG  -> FROZ [label="KG anchor"];
}
