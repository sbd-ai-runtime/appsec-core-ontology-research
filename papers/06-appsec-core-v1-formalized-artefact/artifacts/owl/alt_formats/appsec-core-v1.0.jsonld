        "@value": "Pedro Farinha (programme-lead, SecurityByDesign-TheoryOfEverything)"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "Bounded AppSec Core v1.0 OWL cut generated from the canonical surface contract, entity schema, cross-slice vocabulary, slice registry, global instance index, human-readable label catalog and source slice drafts. This cut covers first-class v1.0 entities, constitutive CO-Practice and CO-Mechanism relations, stable controlled vocabularies, ten slices and the full indexed instance set (74 COs, 68 Practices, 57 Mechanisms, 57 Artifacts)."
      }
    ],
    "http://purl.org/dc/terms/issued": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-05-08"
      }
    ],
