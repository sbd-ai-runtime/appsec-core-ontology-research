  </ac:ArtifactRole>
  <ac:PracticeFamily rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#PracticeFamilyValidationAndAnalysis">
    <rdfs:label>Validation and Analysis</rdfs:label>
  </ac:PracticeFamily>
  <owl:AnnotationProperty rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#shortLabel">
    <rdfs:label>short label</rdfs:label>
    <rdfs:comment>Human-friendly short label for compact views.</rdfs:comment>
  </owl:AnnotationProperty>
  <ac:MechanismFamily rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#MechanismFamilyIdentityAndTrustControl">
    <rdfs:label>Identity and Trust Control</rdfs:label>
  </ac:MechanismFamily>
