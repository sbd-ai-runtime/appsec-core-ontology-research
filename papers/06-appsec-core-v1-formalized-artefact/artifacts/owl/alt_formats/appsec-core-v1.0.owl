    <rdfs:label>Logs</rdfs:label>
  </ac:DetectableSurface>
  <ac:ObjectiveType rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ObjectiveTypePreventive">
    <rdfs:label>Preventive</rdfs:label>
  </ac:ObjectiveType>
  <ac:ObjectiveType rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ObjectiveTypeGovernance">
    <rdfs:label>Governance</rdfs:label>
  </ac:ObjectiveType>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#Artifact">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
    <rdfs:label>Artifact</rdfs:label>
    <rdfs:comment>Control-relevant or evidence-bearing output used for review, traceability and assurance against AppSec Core ControlObjective instances.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#MechanismFamily">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlledVocabularyValue"/>
    <rdfs:label>Mechanism family</rdfs:label>
    <rdfs:comment>Cross-slice family qualifiers for Mechanism instances (e.g. policy_and_gate_enforcement, validation_and_analysis).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ControlledVocabularyValue">
    <rdfs:label>Controlled vocabulary value</rdfs:label>
    <rdfs:comment>Superclass for stable controlled vocabulary values explicitly modeled in the bounded formal cut.</rdfs:comment>
    <owl:disjointWith rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ObjectiveKind">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlledVocabularyValue"/>
    <rdfs:label>Objective kind</rdfs:label>
    <rdfs:comment>Enumeration of ControlObjective kinds (atomic or composite).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#DetectableSurface">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlledVocabularyValue"/>
    <rdfs:label>Detectable surface</rdfs:label>
    <rdfs:comment>Operational surface where an EvidencePattern is expected to be detectable.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity">
    <rdfs:label>AppSec Core entity</rdfs:label>
    <rdfs:comment>Superclass for first-class AppSec Core v0 entities in the bounded formal cut.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#PracticeFamily">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlledVocabularyValue"/>
    <rdfs:label>Practice family</rdfs:label>
    <rdfs:comment>Cross-slice family qualifiers for Practice instances (e.g. governance_and_review, validation_and_analysis).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ArtifactRole">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlledVocabularyValue"/>
    <rdfs:label>Artifact role</rdfs:label>
    <rdfs:comment>Cross-slice canonical roles for Artifact instances (e.g. configuration, governance_record, report).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#EvidencePattern">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
    <rdfs:label>Evidence pattern</rdfs:label>
    <rdfs:comment>Expected evidence shape used for deterministic review support of AppSec Core ControlObjective satisfaction; declarative first-class class with no populated instances in the bounded V1 cut (target_node_count=0 at V1 release).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ControlObjective">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
    <rdfs:label>Control objective</rdfs:label>
    <rdfs:comment>Reusable AppSec domain constraint or assurance goal that expresses what must hold true in the application security domain, without carrying SbD-ToE manual chapter or requirement structure.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#Mechanism">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
    <rdfs:label>Mechanism</rdfs:label>
    <rdfs:comment>Concrete technical or enforceable means used to implement Practice instances or to directly realise ControlObjective instances.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ObjectiveType">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlledVocabularyValue"/>
    <rdfs:label>Objective type</rdfs:label>
    <rdfs:comment>Enumeration of ControlObjective types (governance/preventive/detective/corrective).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#Slice">
    <rdfs:label>Slice</rdfs:label>
    <rdfs:comment>Methodological slice in the AppSec Core v0 reference set.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#Practice">
    <rdfs:subClassOf rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
    <rdfs:label>Practice</rdfs:label>
    <rdfs:comment>Reusable human or process discipline that should exist independently of a specific tool or runtime product choice, and that helps realise one or more ControlObjective instances.</rdfs:comment>
  </owl:Class>
</rdf:RDF>
