      <ac:Artifact rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ACA_IAT_006">
        <rdfs:label>Approval Record</rdfs:label>
        <ac:artifact_id>ACA-IAT-006</ac:artifact_id>
        <ac:belongsToSlice rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#SliceASC02"/>
      </ac:Artifact>
    </ac:objective_expects_artifact>
  </ac:ControlObjective>
  <ac:ArtifactRole rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ArtifactRoleModel">
    <rdfs:label>Model</rdfs:label>
