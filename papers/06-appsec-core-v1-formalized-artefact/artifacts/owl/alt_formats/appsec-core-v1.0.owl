  <owl:ObjectProperty rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#hasObjectiveKind">
    <rdfs:domain rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlObjective"/>
    <rdfs:range rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ObjectiveKind"/>
    <rdfs:label>has objective kind</rdfs:label>
    <rdfs:comment>Relates a ControlObjective to its kind (atomic or composite).</rdfs:comment>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#isObjectiveKindOf">
        <rdfs:domain rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ObjectiveKind"/>
        <rdfs:range rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ControlObjective"/>
        <rdfs:label>is objective kind of</rdfs:label>
        <rdfs:comment>Inverse of ac:hasObjectiveKind; relates an ObjectiveKind value to ControlObjective instances that have it.</rdfs:comment>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#belongsToSlice">
    <rdfs:domain rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
    <rdfs:range rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#Slice"/>
    <rdfs:label>belongs to slice</rdfs:label>
    <rdfs:comment>Membership relation from an AppSec Core entity instance to its methodological slice (ASC-NN).</rdfs:comment>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#hasMember">
        <rdfs:domain rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#Slice"/>
        <rdfs:range rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#AppSecCoreEntity"/>
        <rdfs:label>has member</rdfs:label>
        <rdfs:comment>Inverse of ac:belongsToSlice; relates a Slice to the AppSec Core entity instances it contains.</rdfs:comment>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
