    <rdfs:label>Operational Record</rdfs:label>
  </ac:ArtifactRole>
  <ac:PracticeFamily rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#PracticeFamilyGovernanceAndReview">
    <rdfs:label>Governance and Review</rdfs:label>
  </ac:PracticeFamily>
  <ac:ArtifactRole rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#ArtifactRoleInventory">
    <rdfs:label>Inventory</rdfs:label>
  </ac:ArtifactRole>
