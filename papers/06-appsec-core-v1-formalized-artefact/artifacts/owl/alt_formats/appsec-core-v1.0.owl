  <owl:ObjectProperty rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#hasCanonicalEvidenceKind">
    <rdfs:domain rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#EvidencePattern"/>
    <rdfs:range rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ArtifactRole"/>
    <rdfs:label>has canonical evidence kind</rdfs:label>
    <rdfs:comment>Relates an EvidencePattern to the canonical evidence kind (typically reusing an ArtifactRole value).</rdfs:comment>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://securitybydesign.dev/ontology/appsec-core/v1#isCanonicalEvidenceKindOf">
        <rdfs:domain rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#ArtifactRole"/>
        <rdfs:range rdf:resource="https://securitybydesign.dev/ontology/appsec-core/v1#EvidencePattern"/>
        <rdfs:label>is canonical evidence kind of</rdfs:label>
        <rdfs:comment>Inverse of ac:hasCanonicalEvidenceKind; relates an ArtifactRole value used as canonical evidence kind to the EvidencePattern that adopts it.</rdfs:comment>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
