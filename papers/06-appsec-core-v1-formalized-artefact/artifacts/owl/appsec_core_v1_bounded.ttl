@prefix ac: <https://securitybydesign.dev/ontology/appsec-core/v1#> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ac:AppSecCoreV1 a owl:Ontology ;
    rdfs:label "AppSec Core v1.1 bounded ontology cut" ;
    rdfs:comment "Bounded AppSec Core v1.0 OWL cut generated from the canonical surface contract, entity schema, cross-slice vocabulary, slice registry, global instance index, human-readable label catalog and source slice drafts. This cut covers first-class v1.0 entities, constitutive CO-Practice and CO-Mechanism relations, stable controlled vocabularies, ten slices and the full indexed instance set (74 COs, 68 Practices, 57 Mechanisms, 57 Artifacts)." ;
    dcterms:title "AppSec Core V1 — Application Security Control Objective Ontology" ;
    dcterms:description "Bounded AppSec Core v1.0 OWL cut generated from the canonical surface contract, entity schema, cross-slice vocabulary, slice registry, global instance index, human-readable label catalog and source slice drafts. This cut covers first-class v1.0 entities, constitutive CO-Practice and CO-Mechanism relations, stable controlled vocabularies, ten slices and the full indexed instance set (74 COs, 68 Practices, 57 Mechanisms, 57 Artifacts)." ;
    owl:versionInfo "1.0" ;
    owl:versionIRI <https://securitybydesign.dev/ontology/appsec-core/v1.1> ;
    vann:preferredNamespacePrefix "ac" ;
    vann:preferredNamespaceUri "https://securitybydesign.dev/ontology/appsec-core/v1#" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rights "Licensed under Creative Commons Attribution 4.0 International (CC BY 4.0). See LICENSE in source repository." ;
    dcterms:creator "Pedro Farinha (programme-lead, SecurityByDesign-TheoryOfEverything)" ;
    dcterms:publisher "SecurityByDesign-TheoryOfEverything programme" ;
    dcterms:created "2026-04-15"^^xsd:date ;
    dcterms:issued "2026-05-08"^^xsd:date ;
    dcterms:modified "2026-05-10"^^xsd:date ;
    dcterms:bibliographicCitation "Farinha, P. (2026). AppSec Core V1: A Normalization Ontology for Application Security Control Objectives. SecurityByDesign-TheoryOfEverything programme." ;
    foaf:depiction <https://securitybydesign.dev/assets/appsec-core-v1-logo.svg> ;
    adms:status <http://purl.org/adms/status/Completed> ;
    dcterms:source "canonical AppSec Core YAML surfaces in sbd-toe-ontology" .

ac:shortLabel a owl:AnnotationProperty ;
    rdfs:label "short label" ;
    rdfs:comment "Human-friendly short label for compact views." .

ac:diagramLabel a owl:AnnotationProperty ;
    rdfs:label "diagram label" ;
    rdfs:comment "Compact label intended for diagrams or tight visual layouts." .

ac:AppSecCoreEntity a owl:Class ;
    rdfs:label "AppSec Core entity" ;
    rdfs:comment "Superclass for first-class AppSec Core v0 entities in the bounded formal cut." .

ac:ControlledVocabularyValue a owl:Class ;
    rdfs:label "Controlled vocabulary value" ;
    rdfs:comment "Superclass for stable controlled vocabulary values explicitly modeled in the bounded formal cut." ;
    owl:disjointWith ac:AppSecCoreEntity .

ac:Slice a owl:Class ;
    rdfs:label "Slice" ;
    rdfs:comment "Methodological slice in the AppSec Core v0 reference set." .

ac:ObjectiveKind a owl:Class ;
    rdfs:subClassOf ac:ControlledVocabularyValue ;
    rdfs:label "Objective kind" ;
    rdfs:comment "Enumeration of ControlObjective kinds (atomic or composite)." .

ac:ObjectiveType a owl:Class ;
    rdfs:subClassOf ac:ControlledVocabularyValue ;
    rdfs:label "Objective type" ;
    rdfs:comment "Enumeration of ControlObjective types (governance/preventive/detective/corrective)." .

ac:ArtifactRole a owl:Class ;
    rdfs:subClassOf ac:ControlledVocabularyValue ;
    rdfs:label "Artifact role" ;
    rdfs:comment "Cross-slice canonical roles for Artifact instances (e.g. configuration, governance_record, report)." .

ac:PracticeFamily a owl:Class ;
    rdfs:subClassOf ac:ControlledVocabularyValue ;
    rdfs:label "Practice family" ;
    rdfs:comment "Cross-slice family qualifiers for Practice instances (e.g. governance_and_review, validation_and_analysis)." .

ac:MechanismFamily a owl:Class ;
    rdfs:subClassOf ac:ControlledVocabularyValue ;
    rdfs:label "Mechanism family" ;
    rdfs:comment "Cross-slice family qualifiers for Mechanism instances (e.g. policy_and_gate_enforcement, validation_and_analysis)." .

ac:DetectableSurface a owl:Class ;
    rdfs:subClassOf ac:ControlledVocabularyValue ;
    rdfs:label "Detectable surface" ;
    rdfs:comment "Operational surface where an EvidencePattern is expected to be detectable." .

ac:ControlObjective a owl:Class ;
    rdfs:subClassOf ac:AppSecCoreEntity ;
    rdfs:label "Control objective" ;
    rdfs:comment "Reusable AppSec domain constraint or assurance goal that expresses what must hold true in the application security domain, without carrying SbD-ToE manual chapter or requirement structure." .

ac:Practice a owl:Class ;
    rdfs:subClassOf ac:AppSecCoreEntity ;
    rdfs:label "Practice" ;
    rdfs:comment "Reusable human or process discipline that should exist independently of a specific tool or runtime product choice, and that helps realise one or more ControlObjective instances." .

ac:Mechanism a owl:Class ;
    rdfs:subClassOf ac:AppSecCoreEntity ;
    rdfs:label "Mechanism" ;
    rdfs:comment "Concrete technical or enforceable means used to implement Practice instances or to directly realise ControlObjective instances." .

ac:Artifact a owl:Class ;
    rdfs:subClassOf ac:AppSecCoreEntity ;
    rdfs:label "Artifact" ;
    rdfs:comment "Control-relevant or evidence-bearing output used for review, traceability and assurance against AppSec Core ControlObjective instances." .

ac:EvidencePattern a owl:Class ;
    rdfs:subClassOf ac:AppSecCoreEntity ;
    rdfs:label "Evidence pattern" ;
    rdfs:comment "Expected evidence shape used for deterministic review support of AppSec Core ControlObjective satisfaction; declarative first-class class with no populated instances in the bounded V1 cut (target_node_count=0 at V1 release)." .

[] a owl:AllDisjointClasses ;
    owl:members ( ac:ControlObjective ac:Practice ac:Mechanism ac:Artifact ac:EvidencePattern ) .

ac:belongsToSlice a owl:ObjectProperty ;
    rdfs:domain ac:AppSecCoreEntity ;
    rdfs:range ac:Slice ;
    rdfs:label "belongs to slice" ;
    rdfs:comment "Membership relation from an AppSec Core entity instance to its methodological slice (ASC-NN)." ;
    owl:inverseOf ac:hasMember .

ac:hasMember a owl:ObjectProperty ;
    rdfs:domain ac:Slice ;
    rdfs:range ac:AppSecCoreEntity ;
    rdfs:label "has member" ;
    rdfs:comment "Inverse of ac:belongsToSlice; relates a Slice to the AppSec Core entity instances it contains." .

ac:hasObjectiveKind a owl:ObjectProperty ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range ac:ObjectiveKind ;
    rdfs:label "has objective kind" ;
    rdfs:comment "Relates a ControlObjective to its kind (atomic or composite)." ;
    owl:inverseOf ac:isObjectiveKindOf .

ac:isObjectiveKindOf a owl:ObjectProperty ;
    rdfs:domain ac:ObjectiveKind ;
    rdfs:range ac:ControlObjective ;
    rdfs:label "is objective kind of" ;
    rdfs:comment "Inverse of ac:hasObjectiveKind; relates an ObjectiveKind value to ControlObjective instances that have it." .

ac:hasObjectiveType a owl:ObjectProperty ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range ac:ObjectiveType ;
    rdfs:label "has objective type" ;
    rdfs:comment "Relates a ControlObjective to its objective type (governance/preventive/detective/corrective)." ;
    owl:inverseOf ac:isObjectiveTypeOf .

ac:isObjectiveTypeOf a owl:ObjectProperty ;
    rdfs:domain ac:ObjectiveType ;
    rdfs:range ac:ControlObjective ;
    rdfs:label "is objective type of" ;
    rdfs:comment "Inverse of ac:hasObjectiveType; relates an ObjectiveType value to ControlObjective instances that have it." .

ac:hasPracticeFamily a owl:ObjectProperty ;
    rdfs:domain ac:Practice ;
    rdfs:range ac:PracticeFamily ;
    rdfs:label "has practice family" ;
    rdfs:comment "Relates a Practice to its cross-slice practice family qualifier." ;
    owl:inverseOf ac:isPracticeFamilyOf .

ac:isPracticeFamilyOf a owl:ObjectProperty ;
    rdfs:domain ac:PracticeFamily ;
    rdfs:range ac:Practice ;
    rdfs:label "is practice family of" ;
    rdfs:comment "Inverse of ac:hasPracticeFamily; relates a PracticeFamily value to Practice instances that have it." .

ac:hasMechanismFamily a owl:ObjectProperty ;
    rdfs:domain ac:Mechanism ;
    rdfs:range ac:MechanismFamily ;
    rdfs:label "has mechanism family" ;
    rdfs:comment "Relates a Mechanism to its cross-slice mechanism family qualifier." ;
    owl:inverseOf ac:isMechanismFamilyOf .

ac:isMechanismFamilyOf a owl:ObjectProperty ;
    rdfs:domain ac:MechanismFamily ;
    rdfs:range ac:Mechanism ;
    rdfs:label "is mechanism family of" ;
    rdfs:comment "Inverse of ac:hasMechanismFamily; relates a MechanismFamily value to Mechanism instances that have it." .

ac:hasCanonicalArtifactRole a owl:ObjectProperty ;
    rdfs:domain ac:Artifact ;
    rdfs:range ac:ArtifactRole ;
    rdfs:label "has canonical artifact role" ;
    rdfs:comment "Relates an Artifact to its canonical role in the AppSec Core taxonomy." ;
    owl:inverseOf ac:isCanonicalArtifactRoleOf .

ac:isCanonicalArtifactRoleOf a owl:ObjectProperty ;
    rdfs:domain ac:ArtifactRole ;
    rdfs:range ac:Artifact ;
    rdfs:label "is canonical artifact role of" ;
    rdfs:comment "Inverse of ac:hasCanonicalArtifactRole; relates an ArtifactRole value to Artifact instances that have it." .

ac:hasCanonicalEvidenceKind a owl:ObjectProperty ;
    rdfs:domain ac:EvidencePattern ;
    rdfs:range ac:ArtifactRole ;
    rdfs:label "has canonical evidence kind" ;
    rdfs:comment "Relates an EvidencePattern to the canonical evidence kind (typically reusing an ArtifactRole value)." ;
    owl:inverseOf ac:isCanonicalEvidenceKindOf .

ac:isCanonicalEvidenceKindOf a owl:ObjectProperty ;
    rdfs:domain ac:ArtifactRole ;
    rdfs:range ac:EvidencePattern ;
    rdfs:label "is canonical evidence kind of" ;
    rdfs:comment "Inverse of ac:hasCanonicalEvidenceKind; relates an ArtifactRole value used as canonical evidence kind to the EvidencePattern that adopts it." .

ac:detectableInSurface a owl:ObjectProperty ;
    rdfs:domain ac:EvidencePattern ;
    rdfs:range ac:DetectableSurface ;
    rdfs:label "detectable in surface" ;
    rdfs:comment "Relates an EvidencePattern to the detectable surface where the evidence is expected to manifest." ;
    owl:inverseOf ac:surfaceOfDetectableEvidencePattern .

ac:surfaceOfDetectableEvidencePattern a owl:ObjectProperty ;
    rdfs:domain ac:DetectableSurface ;
    rdfs:range ac:EvidencePattern ;
    rdfs:label "surface of detectable evidence pattern" ;
    rdfs:comment "Inverse of ac:detectableInSurface; relates a DetectableSurface to EvidencePattern instances detectable on it." .

ac:objective_realized_by_practice a owl:ObjectProperty ;
    rdfs:label "objective realized by practice" ;
    rdfs:comment "Relates a ControlObjective to a Practice that realises it operationally." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range ac:Practice ;
    owl:inverseOf ac:practice_realizes_objective .

ac:objective_implemented_by_mechanism a owl:ObjectProperty ;
    rdfs:label "objective implemented by mechanism" ;
    rdfs:comment "Relates a ControlObjective to a Mechanism that implements it technically." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range ac:Mechanism ;
    owl:inverseOf ac:mechanism_implements_objective .

ac:objective_expects_artifact a owl:ObjectProperty ;
    rdfs:label "objective expects artifact" ;
    rdfs:comment "Relates a ControlObjective to an Artifact whose presence is expected as evidence of the objective." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range ac:Artifact ;
    owl:inverseOf ac:artifact_supports_objective .

ac:objective_verified_by_evidence_pattern a owl:ObjectProperty ;
    rdfs:label "objective verified by evidence pattern" ;
    rdfs:comment "Relates a ControlObjective to an EvidencePattern that supports its deterministic review." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range ac:EvidencePattern ;
    owl:inverseOf ac:evidence_pattern_verifies_objective .

ac:artifact_supports_evidence_pattern a owl:ObjectProperty ;
    rdfs:label "artifact supports evidence pattern" ;
    rdfs:comment "Relates an Artifact to an EvidencePattern it supports as evidence." ;
    rdfs:domain ac:Artifact ;
    rdfs:range ac:EvidencePattern ;
    owl:inverseOf ac:evidence_pattern_supported_by_artifact .

ac:practice_realizes_objective a owl:ObjectProperty ;
    rdfs:label "practice realizes objective" ;
    rdfs:comment "Inverse of ac:objective_realized_by_practice; relates a controlobjective to a practice that realises it operationally." ;
    rdfs:domain ac:Practice ;
    rdfs:range ac:ControlObjective .

ac:mechanism_implements_objective a owl:ObjectProperty ;
    rdfs:label "mechanism implements objective" ;
    rdfs:comment "Inverse of ac:objective_implemented_by_mechanism; relates a controlobjective to a mechanism that implements it technically." ;
    rdfs:domain ac:Mechanism ;
    rdfs:range ac:ControlObjective .

ac:artifact_supports_objective a owl:ObjectProperty ;
    rdfs:label "artifact supports objective" ;
    rdfs:comment "Inverse of ac:objective_expects_artifact; relates a controlobjective to an artifact whose presence is expected as evidence of the objective." ;
    rdfs:domain ac:Artifact ;
    rdfs:range ac:ControlObjective .

ac:evidence_pattern_verifies_objective a owl:ObjectProperty ;
    rdfs:label "evidence pattern verifies objective" ;
    rdfs:comment "Inverse of ac:objective_verified_by_evidence_pattern; relates a controlobjective to an evidencepattern that supports its deterministic review." ;
    rdfs:domain ac:EvidencePattern ;
    rdfs:range ac:ControlObjective .

ac:evidence_pattern_supported_by_artifact a owl:ObjectProperty ;
    rdfs:label "evidence pattern supported by artifact" ;
    rdfs:comment "Inverse of ac:artifact_supports_evidence_pattern; relates an artifact to an evidencepattern it supports as evidence." ;
    rdfs:domain ac:EvidencePattern ;
    rdfs:range ac:Artifact .

ac:slice_id a owl:DatatypeProperty ;
    rdfs:domain ac:Slice ;
    rdfs:range xsd:string ;
    rdfs:label "slice ID" ;
    rdfs:comment "Stable identifier for an AppSec Core Slice (matches ASC-NN pattern)." .

ac:scope_key a owl:DatatypeProperty ;
    rdfs:domain ac:Slice ;
    rdfs:range xsd:string ;
    rdfs:label "scope key" ;
    rdfs:comment "Canonical scope label for the slice (e.g. input_output_data_safety_and_controlled_failure)." .

ac:objective_family_code a owl:DatatypeProperty ;
    rdfs:domain ac:Slice ;
    rdfs:range xsd:string ;
    rdfs:label "objective family code" ;
    rdfs:comment "Family code shared by all ControlObjective instances inside the slice (e.g. ACO-IVF)." .

ac:current_control_mode a owl:DatatypeProperty ;
    rdfs:domain ac:Slice ;
    rdfs:range xsd:string ;
    rdfs:label "current control mode" ;
    rdfs:comment "Slice control-mode descriptor at the current AppSec Core release (e.g. single_broad_control_surface)." .

ac:contract_path a owl:DatatypeProperty ;
    rdfs:domain ac:Slice ;
    rdfs:range xsd:string ;
    rdfs:label "contract path" ;
    rdfs:comment "Repository-relative path to the slice contract YAML in sbd-toe-ontology." .

ac:artifact_id a owl:DatatypeProperty ;
    rdfs:label "artifact ID" ;
    rdfs:comment "Stable identifier for an Artifact instance (matches ACA-<SLICE>-<NNN> pattern)." ;
    rdfs:domain ac:Artifact ;
    rdfs:range xsd:string .

ac:domain_key a owl:DatatypeProperty ;
    rdfs:label "domain key" ;
    rdfs:comment "Slice-local domain key categorising a ControlObjective." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range xsd:string .

ac:evidence_pattern_id a owl:DatatypeProperty ;
    rdfs:label "evidence pattern ID" ;
    rdfs:comment "Stable identifier for an EvidencePattern instance." ;
    rdfs:domain ac:EvidencePattern ;
    rdfs:range xsd:string .

ac:expectation a owl:DatatypeProperty ;
    rdfs:label "expectation" ;
    rdfs:comment "Expected evidence shape that supports deterministic review of an EvidencePattern." ;
    rdfs:domain ac:EvidencePattern ;
    rdfs:range xsd:string .

ac:expected_outcome a owl:DatatypeProperty ;
    rdfs:label "expected outcome" ;
    rdfs:comment "Behavioural outcome that a ControlObjective expects to observe when satisfied." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range xsd:string .

ac:local_mechanism_type a owl:DatatypeProperty ;
    rdfs:label "local mechanism type" ;
    rdfs:comment "Slice-local typing for a Mechanism (e.g. rulepack, context_encoder)." ;
    rdfs:domain ac:Mechanism ;
    rdfs:range xsd:string .

ac:local_practice_type a owl:DatatypeProperty ;
    rdfs:label "local practice type" ;
    rdfs:comment "Slice-local typing for a Practice (e.g. contract_validation, output_encoding)." ;
    rdfs:domain ac:Practice ;
    rdfs:range xsd:string .

ac:mechanism_id a owl:DatatypeProperty ;
    rdfs:label "mechanism ID" ;
    rdfs:comment "Stable identifier for a Mechanism instance (matches ACM-<SLICE>-<NNN> pattern)." ;
    rdfs:domain ac:Mechanism ;
    rdfs:range xsd:string .

ac:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Human-readable name for the AppSec Core entity instance." ;
    rdfs:domain ac:AppSecCoreEntity ;
    rdfs:range xsd:string .

ac:objective_id a owl:DatatypeProperty ;
    rdfs:label "objective ID" ;
    rdfs:comment "Stable identifier for a ControlObjective instance (matches ACO-<SLICE>-<NNN> pattern)." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range xsd:string .

ac:practice_id a owl:DatatypeProperty ;
    rdfs:label "practice ID" ;
    rdfs:comment "Stable identifier for a Practice instance (matches ACP-<SLICE>-<NNN> pattern)." ;
    rdfs:domain ac:Practice ;
    rdfs:range xsd:string .

ac:statement a owl:DatatypeProperty ;
    rdfs:label "statement" ;
    rdfs:comment "Normative statement of what a ControlObjective requires to hold true in the application security domain." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range xsd:string .

ac:validation_method a owl:DatatypeProperty ;
    rdfs:label "validation method" ;
    rdfs:comment "Method describing how an EvidencePattern is interpreted (not its execution binding)." ;
    rdfs:domain ac:EvidencePattern ;
    rdfs:range xsd:string .

ac:verification_posture a owl:DatatypeProperty ;
    rdfs:label "verification posture" ;
    rdfs:comment "Assurance stance qualifier indicating how a ControlObjective is verified." ;
    rdfs:domain ac:ControlObjective ;
    rdfs:range xsd:string .

ac:ObjectiveKindAtomic a ac:ObjectiveKind ;
    rdfs:label "Atomic" .

ac:ObjectiveKindComposite a ac:ObjectiveKind ;
    rdfs:label "Composite" .

ac:ObjectiveTypeGovernance a ac:ObjectiveType ;
    rdfs:label "Governance" .

ac:ObjectiveTypePreventive a ac:ObjectiveType ;
    rdfs:label "Preventive" .

ac:ObjectiveTypeDetective a ac:ObjectiveType ;
    rdfs:label "Detective" .

ac:ObjectiveTypeCorrective a ac:ObjectiveType ;
    rdfs:label "Corrective" .

ac:ArtifactRoleConfiguration a ac:ArtifactRole ;
    rdfs:label "Configuration" .

ac:ArtifactRoleGovernanceRecord a ac:ArtifactRole ;
    rdfs:label "Governance Record" .

ac:ArtifactRoleReviewRecord a ac:ArtifactRole ;
    rdfs:label "Review Record" .

ac:ArtifactRoleApprovalRecord a ac:ArtifactRole ;
    rdfs:label "Approval Record" .

ac:ArtifactRoleGateRecord a ac:ArtifactRole ;
    rdfs:label "Gate Record" .

ac:ArtifactRoleInventory a ac:ArtifactRole ;
    rdfs:label "Inventory" .

ac:ArtifactRoleAttestation a ac:ArtifactRole ;
    rdfs:label "Attestation" .

ac:ArtifactRoleReport a ac:ArtifactRole ;
    rdfs:label "Report" .

ac:ArtifactRoleEvidencePackage a ac:ArtifactRole ;
    rdfs:label "Evidence Package" .

ac:ArtifactRoleOperationalRecord a ac:ArtifactRole ;
    rdfs:label "Operational Record" .

ac:ArtifactRoleBuildDefinition a ac:ArtifactRole ;
    rdfs:label "Build Definition" .

ac:ArtifactRoleReleaseArtifact a ac:ArtifactRole ;
    rdfs:label "Release Artifact" .

ac:ArtifactRoleModel a ac:ArtifactRole ;
    rdfs:label "Model" .

ac:ArtifactRoleValidationOutput a ac:ArtifactRole ;
    rdfs:label "Validation Output" .

ac:ArtifactRoleBindingRecord a ac:ArtifactRole ;
    rdfs:label "Binding Record" .

ac:PracticeFamilyGovernanceAndReview a ac:PracticeFamily ;
    rdfs:label "Governance and Review" .

ac:PracticeFamilyPolicyAndGateEnforcement a ac:PracticeFamily ;
    rdfs:label "Policy and Gate Enforcement" .

ac:PracticeFamilyIdentityAndTrustControl a ac:PracticeFamily ;
    rdfs:label "Identity and Trust Control" .

ac:PracticeFamilyValidationAndAnalysis a ac:PracticeFamily ;
    rdfs:label "Validation and Analysis" .

ac:PracticeFamilyIntegrityTraceabilityAndRecords a ac:PracticeFamily ;
    rdfs:label "Integrity Traceability and Records" .

ac:PracticeFamilyRolloutRecoveryAndRuntimeRecords a ac:PracticeFamily ;
    rdfs:label "Rollout Recovery and Runtime Records" .

ac:MechanismFamilyGovernanceAndReview a ac:MechanismFamily ;
    rdfs:label "Governance and Review" .

ac:MechanismFamilyPolicyAndGateEnforcement a ac:MechanismFamily ;
    rdfs:label "Policy and Gate Enforcement" .

ac:MechanismFamilyIdentityAndTrustControl a ac:MechanismFamily ;
    rdfs:label "Identity and Trust Control" .

ac:MechanismFamilyValidationAndAnalysis a ac:MechanismFamily ;
    rdfs:label "Validation and Analysis" .

ac:MechanismFamilyIntegrityTraceabilityAndRecords a ac:MechanismFamily ;
    rdfs:label "Integrity Traceability and Records" .

ac:MechanismFamilyRolloutRecoveryAndRuntimeRecords a ac:MechanismFamily ;
    rdfs:label "Rollout Recovery and Runtime Records" .

ac:DetectableSurfaceCiCd a ac:DetectableSurface ;
    rdfs:label "CI/CD" .

ac:DetectableSurfaceLogs a ac:DetectableSurface ;
    rdfs:label "Logs" .

ac:DetectableSurfaceDocumentation a ac:DetectableSurface ;
    rdfs:label "Documentation" .

ac:DetectableSurfaceConfig a ac:DetectableSurface ;
    rdfs:label "Config" .

ac:SliceASC01 a ac:Slice ;
    rdfs:label "Supply chain and build integrity" ;
    rdfs:comment "supply chain and build integrity" ;
    ac:slice_id "ASC-01" ;
    ac:scope_key "supply_chain_and_build_integrity" ;
    ac:objective_family_code "ACO-SCBI" ;
    ac:current_control_mode "multi_control_convergent_surface" ;
    ac:contract_path "ontology/appsec-core-supply-chain-build-integrity-slice-contract.yaml" ;
    ac:shortLabel "Supply chain integrity" ;
    ac:diagramLabel "SC integrity" .

ac:SliceASC02 a ac:Slice ;
    rdfs:label "Identity, access and session trust" ;
    rdfs:comment "identity access and session trust" ;
    ac:slice_id "ASC-02" ;
    ac:scope_key "identity_access_and_session_trust" ;
    ac:objective_family_code "ACO-IAT" ;
    ac:current_control_mode "single_broad_control_surface" ;
    ac:contract_path "ontology/appsec-core-identity-access-session-trust-slice-contract.yaml" ;
    ac:shortLabel "Identity and access trust" ;
    ac:diagramLabel "Identity trust" .

ac:SliceASC03 a ac:Slice ;
    rdfs:label "Architecture and trust boundaries" ;
    rdfs:comment "architecture and trust boundaries" ;
    ac:slice_id "ASC-03" ;
    ac:scope_key "architecture_and_trust_boundaries" ;
    ac:objective_family_code "ACO-ATB" ;
    ac:current_control_mode "dual_control_surface" ;
    ac:contract_path "ontology/appsec-core-architecture-trust-boundaries-slice-contract.yaml" ;
    ac:shortLabel "Architecture and boundaries" ;
    ac:diagramLabel "Architecture boundaries" .

ac:SliceASC04 a ac:Slice ;
    rdfs:label "Testing, security validation and empirical assurance" ;
    rdfs:comment "testing security validation and empirical assurance" ;
    ac:slice_id "ASC-04" ;
    ac:scope_key "testing_security_validation_and_empirical_assurance" ;
    ac:objective_family_code "ACO-TSV" ;
    ac:current_control_mode "single_broad_control_surface" ;
    ac:contract_path "ontology/appsec-core-testing-security-validation-slice-contract.yaml" ;
    ac:shortLabel "Security validation and assurance" ;
    ac:diagramLabel "Security validation" .

ac:SliceASC05 a ac:Slice ;
    rdfs:label "Threat modeling, risk disposition and mitigation traceability" ;
    rdfs:comment "threat modeling risk disposition and mitigation traceability" ;
    ac:slice_id "ASC-05" ;
    ac:scope_key "threat_modeling_risk_disposition_and_mitigation_traceability" ;
    ac:objective_family_code "ACO-TMR" ;
    ac:current_control_mode "single_broad_control_surface" ;
    ac:contract_path "ontology/appsec-core-threat-modeling-risk-disposition-slice-contract.yaml" ;
    ac:shortLabel "Threat modeling and risk traceability" ;
    ac:diagramLabel "Threat and risk" .

ac:SliceASC06 a ac:Slice ;
    rdfs:label "Secret handling, protected configuration and operational identities" ;
